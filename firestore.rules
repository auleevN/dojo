rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields:
    //   - email: string (required)
    //   - role: string (required, 'member' or 'admin')
    //   - displayName: string (optional)
    //
    // Collection: videos
    // Fields:
    //   - title: string (required)
    //   - description: string (optional)
    //   - category: string (required)
    //   - url: string (required)
    //   - duration: string (optional)
    //   - createdAt: timestamp (required)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "olivier.mobilebox@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role']) &&
             data.email is string &&
             data.role in ['member', 'admin'];
    }

    function isValidVideo(data) {
      return data.keys().hasAll(['title', 'category', 'url', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.category is string &&
             data.url is string &&
             data.createdAt is timestamp;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'member';
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role && isValidUser(request.resource.data));
      allow delete: if isAdmin();
    }

    match /videos/{videoId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidVideo(request.resource.data);
    }
  }
}
